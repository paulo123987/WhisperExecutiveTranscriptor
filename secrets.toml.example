# ═══════════════════════════════════════════════════════════════════════════════
#  Exemplo de Configuração - .streamlit/secrets.toml
# ═══════════════════════════════════════════════════════════════════════════════
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para: .streamlit/secrets.toml
# 2. Preencha suas API Keys reais
# 3. NUNCA versione o arquivo secrets.toml no git!
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── HuggingFace Token (OBRIGATÓRIO para WhisperX) ──────────────────────────────
# Gere em: https://huggingface.co/settings/tokens
# Aceite termos: 
#   - https://huggingface.co/pyannote/speaker-diarization-3.1
#   - https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN = "hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── OpenAI API Key (Opcional) ──────────────────────────────────────────────────
# Para redação PII via IA e análise de insights
# Gere em: https://platform.openai.com/api-keys
OPENAI_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Groq API Key (Opcional) ────────────────────────────────────────────────────
# Alternativa rápida e gratuita para LLM
# Gere em: https://console.groq.com/keys
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Oracle Database (Opcional) ─────────────────────────────────────────────────
# Necessário apenas para a aba "Consulta Oracle" (amostragem estatística)
# DSN pode ser: host:porta/service_name  ou  TNS alias configurado em tnsnames.ora
ORACLE_USER     = "meu_usuario"
ORACLE_PASSWORD = "minha_senha"
ORACLE_DSN      = "oracle-host:1521/ORCL"

# ═══════════════════════════════════════════════════════════════════════════════
#  NOTAS:
# ═══════════════════════════════════════════════════════════════════════════════
#
# 🔐 Segurança:
#   - Nunca compartilhe este arquivo
#   - Nunca faça commit no git
#   - Rotacione tokens periodicamente
#
# ✅ Prioridade:
#   1. HF_TOKEN — Essencial para WhisperX/Pyannote
#   2. OpenAI ou Groq — Apenas se usar redação IA ou insights
#
# 🆓 Gratuito:
#   - HuggingFace Token: Grátis (acesso a modelos)
#   - Groq API: Grátis (com limites generosos)
#   - OpenAI: Pago (mas gpt-4o-mini é muito barato)
#
# ═══════════════════════════════════════════════════════════════════════════════
